<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= serviceName %> - Blinkit Microservices</title>
    <style>
      body { font-family: Arial, sans-serif; margin: 0; background: linear-gradient(180deg, #fffaf3 0%, #f8fff9 100%); color: #183a1d; }
      .container { max-width: 1200px; margin: 0 auto; padding: 24px; }
      .hero { background: linear-gradient(90deg, #00b843, #34c759); color: white; border-radius: 22px; padding: 24px; box-shadow: 0 10px 24px rgba(0,0,0,0.08); }
      .card { background: white; border-radius: 18px; padding: 16px; box-shadow: 0 8px 24px rgba(0,0,0,0.06); margin-top: 16px; }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; margin-top: 16px; }
      .item-card { border: 1px solid #e9efe8; border-radius: 14px; padding: 12px; background: #fcfffc; }
      .badge { display: inline-block; font-size: 12px; padding: 4px 8px; border-radius: 999px; background: #e8fff1; color: #1f8e3f; margin-bottom: 8px; }
      .btn { display: inline-block; margin-top: 12px; text-decoration: none; padding: 10px 14px; border-radius: 10px; background: linear-gradient(90deg, #00b843, #34c759); color: white; font-weight: 700; }
      .muted { color: #5f6f65; font-size: 13px; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="hero">
        <h1><%= title %></h1>
        <p><%= description %></p>
        <a href="/" class="btn">Back to home</a>
      </div>

      <div class="card">
        <h3>Live service catalogue</h3>
        <p class="muted">Showing a large list of realistic items for this domain, similar to a real Blinkit service view.</p>
        <div class="grid">
          <% items.forEach(item => { %>
            <div class="item-card">
              <div class="badge"><%= item.badge %></div>
              <strong><%= item.name %></strong>
              <p class="muted"><%= item.detail %></p>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </body>
</html>
