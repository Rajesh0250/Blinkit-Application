<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blinkit-style Grocery Hub</title>
    <style>
      :root {
        --bg: #fffaf3;
        --card: #ffffff;
        --green: #00b843;
        --green-dark: #1f8e3f;
        --orange: #ff7a00;
        --pink: #ff4d6d;
        --text: #183a1d;
        --muted: #5f6f65;
        --border: #f0e6d2;
      }
      * { box-sizing: border-box; }
      body { font-family: Arial, sans-serif; margin: 0; background: linear-gradient(180deg, #fffaf3 0%, #f8fff9 100%); color: var(--text); }
      .container { max-width: 1280px; margin: 0 auto; padding: 24px; }
      .hero { background: linear-gradient(90deg, var(--green) 0%, #34c759 50%, #ffbf47 100%); color: white; padding: 24px; border-radius: 24px; box-shadow: 0 10px 30px rgba(0,184,67,0.18); }
      .hero h1 { margin: 0 0 8px; font-size: 32px; }
      .hero p { margin: 0; font-size: 16px; opacity: 0.95; }
      .quick-stats { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 16px; }
      .stat { background: rgba(255,255,255,0.2); padding: 8px 12px; border-radius: 999px; font-size: 14px; }
      .layout { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-top: 22px; }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; }
      .card { background: var(--card); border: 1px solid var(--border); border-radius: 18px; padding: 16px; box-shadow: 0 6px 18px rgba(24,58,29,0.06); }
      .section-title { margin: 20px 0 12px; font-size: 22px; }
      .pill { display: inline-block; background: #eafff2; color: var(--green-dark); border-radius: 999px; padding: 4px 8px; font-size: 12px; font-weight: 700; margin-bottom: 8px; }
      .emoji { font-size: 30px; margin-bottom: 8px; display: block; }
      .price-row { display: flex; justify-content: space-between; align-items: center; margin-top: 10px; }
      .price { font-size: 20px; font-weight: 700; color: var(--green-dark); }
      .old-price { color: var(--muted); text-decoration: line-through; font-size: 13px; }
      .discount-badge { background: #ffe8d8; color: var(--orange); padding: 4px 8px; border-radius: 999px; font-size: 12px; font-weight: 700; }
      .stock { font-size: 12px; color: var(--muted); margin-top: 6px; }
      button { border: none; padding: 10px 14px; border-radius: 10px; cursor: pointer; font-weight: 700; }
      .add-btn { background: linear-gradient(90deg, var(--green) 0%, #41cc63 100%); color: white; width: 100%; margin-top: 10px; }
      .checkout-btn { background: linear-gradient(90deg, var(--pink) 0%, #ff6b6b 100%); color: white; width: 100%; margin-top: 10px; }
      .cart { position: sticky; top: 16px; align-self: start; }
      .cart-card { background: linear-gradient(180deg, #fff 0%, #fffaf3 100%); border: 1px solid var(--border); border-radius: 18px; padding: 16px; }
      .cart-item { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px dashed #ecdcc5; }
      .cart-total { font-size: 22px; font-weight: 800; color: var(--green-dark); margin-top: 8px; }
      .muted { color: var(--muted); font-size: 14px; }
      .section-row { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 10px; }
      .tag { background: #f5fff7; border: 1px solid #dff7e4; color: var(--green-dark); padding: 6px 10px; border-radius: 999px; font-size: 13px; }
      .toast { margin-top: 10px; padding: 8px 10px; border-radius: 10px; background: #e8fff1; color: var(--green-dark); font-size: 13px; }
      @media (max-width: 920px) { .layout { grid-template-columns: 1fr; } .cart { position: relative; top: 0; } }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="hero">
        <h1>Fresh groceries delivered in minutes</h1>
        <p>Pick fruits, daily essentials, kitchen staples, and pantry favourites in one colorful cart.</p>
        <div class="quick-stats">
          <span class="stat">⚡ 10 min delivery</span>
          <span class="stat">💸 Up to 40% off today</span>
          <span class="stat">🥬 1000+ items</span>
        </div>
      </div>

      <div class="layout">
        <div>
          <div class="card" style="margin-bottom: 16px;">
            <h3>Login / Register</h3>
            <input id="username" placeholder="Username" style="width:100%; padding:8px; margin-bottom:8px;" />
            <input id="password" type="password" placeholder="Password" style="width:100%; padding:8px; margin-bottom:8px;" />
            <div style="display:flex; gap:8px; flex-wrap:wrap;">
              <button class="add-btn" style="width:auto;" onclick="loginUser()">Login</button>
              <button class="checkout-btn" style="width:auto;" onclick="registerUser()">Register</button>
            </div>
            <div id="authMessage" class="toast" style="display:none"></div>
          </div>

          <h2 class="section-title">Shop by category</h2>
          <div class="section-row">
            <a class="tag" href="/category/All" style="text-decoration:none;">🛍️ All</a>
            <a class="tag" href="/category/Fruits" style="text-decoration:none;">🥭 Fruits</a>
            <a class="tag" href="/category/Vegetables" style="text-decoration:none;">🥬 Vegetables</a>
            <a class="tag" href="/category/Groceries" style="text-decoration:none;">🛒 Groceries</a>
            <a class="tag" href="/category/Pharmacy" style="text-decoration:none;">💊 Pharmacy</a>
            <a class="tag" href="/category/Kitchen%20Essentials" style="text-decoration:none;">🍳 Kitchen Essentials</a>
            <a class="tag" href="/category/Household" style="text-decoration:none;">🧴 Household</a>
          </div>

          <div class="section-row" style="margin-top: 8px;">
            <a class="tag" href="/service/user-service" style="text-decoration:none;">👤 User Service</a>
            <a class="tag" href="/service/profile-service" style="text-decoration:none;">🧾 Profile Service</a>
            <a class="tag" href="/service/address-service" style="text-decoration:none;">📍 Address Service</a>
            <a class="tag" href="/service/catalog-service" style="text-decoration:none;">🧺 Catalog Service</a>
            <a class="tag" href="/service/cart-service" style="text-decoration:none;">🛒 Cart Service</a>
            <a class="tag" href="/service/payment-service" style="text-decoration:none;">💳 Payment Service</a>
          </div>
          <% if (selectedCategory && selectedCategory !== 'All') { %>
            <div class="pill" style="margin-bottom: 10px;">Showing: <%= selectedCategory %></div>
          <% } %>

          <%
            const discountMap = {
              Fruit: 18,
              Fruits: 18,
              Vegetables: 12,
              Groceries: 10,
              Pharmacy: 15,
              'Kitchen Essentials': 8,
              Household: 7,
              Bakery: 6,
              Dairy: 8,
              Beverages: 9,
              Snacks: 6,
              'Daily Essentials': 10
            };
            const getDiscount = (category) => discountMap[category] || 0;
            const getDiscountedPrice = (price, category) => (Number(price) * (1 - (discountMap[category] || 0) / 100)).toFixed(2);
            const categoryIcons = {
              Fruits: '🍇',
              Vegetables: '🥕',
              Groceries: '🛒',
              Pharmacy: '💊',
              'Kitchen Essentials': '🍳',
              Household: '🧴',
              Bakery: '🥖',
              Dairy: '🥛',
              Beverages: '🥤',
              Snacks: '🍪',
              'Daily Essentials': '🧼'
            };
          %>

          <div class="grid">
            <% products.forEach(product => { %>
              <% const discount = getDiscount(product.category); const discountedPrice = getDiscountedPrice(product.price, product.category); %>
              <div class="card">
                <span class="pill"><%= product.category %></span>
                <span class="emoji"><%= categoryIcons[product.category] || '🛍️' %></span>
                <h3><%= product.name %></h3>
                <div class="price-row">
                  <div>
                    <div class="price">₹<%= discountedPrice %></div>
                    <div class="old-price">₹<%= Number(product.price).toFixed(2) %></div>
                  </div>
                  <% if (discount > 0) { %>
                    <span class="discount-badge"><%= discount %>% off</span>
                  <% } %>
                </div>
                <div class="stock">Stock: <%= product.stock %> left</div>
                <button class="add-btn" onclick="addToCart('<%= product.name %>', <%= product.price %>, '<%= product.category %>')">Add to cart</button>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="cart">
          <div class="cart-card">
            <h3>Your cart</h3>
            <p class="muted">Tap any item to build your basket.</p>
            <div id="cartItems"></div>
            <div class="cart-total" id="cartTotal">₹0.00</div>
            <div class="muted" id="cartSavings">You save ₹0.00</div>
            <button class="checkout-btn" onclick="checkoutCart()">Place order</button>
            <div id="statusMessage" class="toast" style="display:none"></div>
          </div>
        </div>
      </div>
    </div>

    <script>
      const cart = [];
      let currentToken = '';

      function showAuthMessage(message) {
        const box = document.getElementById('authMessage');
        box.textContent = message;
        box.style.display = 'block';
      }

      async function loginUser() {
        const payload = { username: document.getElementById('username').value, password: document.getElementById('password').value };
        try {
          const res = await fetch('/login', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
          const data = await res.json();
          if (data.token) {
            currentToken = data.token;
            showAuthMessage(`Logged in as ${data.user.username}`);
          } else {
            showAuthMessage(data.message || 'Login failed');
          }
        } catch (error) {
          showAuthMessage('Login failed');
        }
      }

      async function registerUser() {
        const payload = { username: document.getElementById('username').value, password: document.getElementById('password').value };
        try {
          const res = await fetch('/auth/register', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
          const data = await res.json();
          showAuthMessage(data.message || 'Registration completed');
        } catch (error) {
          showAuthMessage('Registration failed');
        }
      }

      function addToCart(name, price, category) {
        const existing = cart.find(item => item.name === name);
        if (existing) {
          existing.quantity += 1;
        } else {
          cart.push({ name, price, category, quantity: 1 });
        }
        renderCart();
        if (currentToken) {
          fetch('/cart/add', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name, price, category, token: currentToken }) });
        }
        showMessage(`${name} added to cart`);
      }

      function renderCart() {
        const cartItems = document.getElementById('cartItems');
        const cartTotal = document.getElementById('cartTotal');
        const cartSavings = document.getElementById('cartSavings');

        if (cart.length === 0) {
          cartItems.innerHTML = '<p class="muted">Your basket is empty.</p>';
          cartTotal.textContent = '₹0.00';
          cartSavings.textContent = 'You save ₹0.00';
          return;
        }

        let subtotal = 0;
        let savings = 0;
        cartItems.innerHTML = '';

        cart.forEach(item => {
          const discount = getDiscount(item.category);
          const discountedPrice = Number(item.price * (1 - discount / 100)).toFixed(2);
          const itemTotal = Number(discountedPrice * item.quantity).toFixed(2);
          subtotal += Number(itemTotal);
          savings += Number((item.price - discountedPrice) * item.quantity).toFixed(2);

          const row = document.createElement('div');
          row.className = 'cart-item';
          row.innerHTML = `
            <div>
              <strong>${item.name}</strong><br/>
              <span class="muted">${item.quantity} × ₹${discountedPrice}</span>
            </div>
            <strong>₹${itemTotal}</strong>
          `;
          cartItems.appendChild(row);
        });

        cartTotal.textContent = `₹${subtotal.toFixed(2)}`;
        cartSavings.textContent = `You save ₹${Number(savings).toFixed(2)}`;
      }

      function getDiscount(category) {
        const map = { Fruit: 18, Fruits: 18, Vegetables: 12, Groceries: 10, 'Kitchen Essentials': 8, Household: 7, Bakery: 6, Dairy: 8, Beverages: 9, Snacks: 6, 'Daily Essentials': 10 };
        return map[category] || 0;
      }

      function showMessage(message) {
        const box = document.getElementById('statusMessage');
        box.textContent = message;
        box.style.display = 'block';
        clearTimeout(showMessage.timeout);
        showMessage.timeout = setTimeout(() => {
          box.style.display = 'none';
        }, 1800);
      }

      async function checkoutCart() {
        if (cart.length === 0) {
          showMessage('Add at least one item to your cart first');
          return;
        }

        const total = cart.reduce((sum, item) => {
          const discount = getDiscount(item.category);
          const discountedPrice = Number(item.price * (1 - discount / 100)).toFixed(2);
          return sum + Number(discountedPrice) * item.quantity;
        }, 0);

        const payload = { customerName: 'Demo Customer', items: cart.map(item => ({ name: item.name, price: item.price, quantity: item.quantity, category: item.category })), total: Number(total).toFixed(2) };

        try {
          const res = await fetch('/checkout', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
          const data = await res.json();
          showMessage(data.message || 'Order placed successfully');
          cart.length = 0;
          renderCart();
        } catch (error) {
          showMessage('Checkout failed. Please try again.');
        }
      }

      renderCart();
    </script>
  </body>
</html>
